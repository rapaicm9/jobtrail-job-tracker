# Environment for the generated docker-compose.yaml.
#
# Copy to `.env` next to the compose file on the deployment host and fill in
# real values. The real `.env` is git-ignored and must never be committed - the
# secrets below belong on the host only.
#
#   cp .env.example .env && edit .env
#
# The compose topology is regenerated with `aspire publish`; keep any new
# variables it introduces mirrored here.

# Images built and pushed by CI (e.g. ghcr.io/<owner>/jobtrail-api:<tag>).
API_IMAGE=
WORKER_IMAGE=

# Port the API listens on inside its container / behind the reverse proxy.
API_PORT=8080

# Backing-service credentials. Generate strong, unique values per environment;
# do not reuse across deployments. These are the crown jewels - host-only.
POSTGRES_PASSWORD=
CACHE_PASSWORD=
